@using Microsoft.AspNetCore.Identity;
@using EH_SEDO_Assignment.Data;
@inject SignInManager<ApplicationUser> signInManager;
@model EH_SEDO_Assignment.ViewModels.Home.HomeViewModel;

@{
    ViewData["Title"] = "Home Page";
}

@if (Model.ShowAlert)
{
    <div class="container">
        <div class="row justify-content-center">
            <div class="alert alert-success alert-dismissible col-6">
                <p class="text-center">@Model.AlertMessage</p>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        </div>
    </div>
}

<div class="text-center">
    <h1 class="display-4">Welcome @Model.Name</h1>
</div>
<hr />
@if (signInManager.IsSignedIn(User))
{
    <div class="container">
        <div class="row">
            <div class="col-lg-3">
            </div>
            <a class="btn btn-primary btn-lg col-2" asp-controller="Users" asp-action="UserAssets">My Assets</a>
            <div class="col-lg-2">
            </div>
            <a class="btn btn-primary btn-lg col-2" asp-controller="Account" asp-action="ChangePassword">Change Password</a>
            <div class="col-lg-3">
            </div>
        </div>
    </div>
}
else
{
    <div class="container">
        <div class="row">
            <div class="col-lg-5">
            </div>
            <a class="btn btn-primary btn-lg col-2" asp-controller="Account" asp-action="Login">Log In</a>
            <div class="col-lg-5">
            </div>
        </div>
    </div>
}

